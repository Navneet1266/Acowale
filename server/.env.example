# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (Postgres connection string, e.g. from Neon)
DATABASE_URL=postgres://user:password@localhost:5432/acowale_feedback

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Seed admin (used only by `npm run seed:admin`)
ADMIN_EMAIL=admin@acowale.com
ADMIN_PASSWORD=change-this-password

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_SUBMISSIONS=5
RATE_LIMIT_MAX_LOGIN=10

# Logging
LOG_LEVEL=info
